{
  "name": "primetrade_intern",
  "version": "1.0.0",
  "description": "Production-ready modular Node.js backend starter with Express and Prisma",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "node -e \"console.log('Build step not required for pure JavaScript runtime.');\"",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
